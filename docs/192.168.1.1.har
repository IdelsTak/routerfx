            "text": "<meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\" />\n<script type=\"text/javascript\" src=\"../../js/info/sysInfo.js\"></script>\n<div\n  id=\"net_info\"\n  v-cloak\n  :style=\"Page.theme != 'main.tot.css' ? 'display: flex;' : ''\"\n>\n  <div class=\"detail_box\" style=\"width: 60%; float: left\">\n    <div>\n      <table class=\"detail\">\n        <tr v-for=\"(name,index) in values_sysInfo\" :key=\"index\">\n          <th style=\"height: 30px; font-size: 16px\">{{index}}</th>\n          <td style=\"width: 60%\" v-html=\"name\"></td>\n        </tr>\n      </table>\n    </div>\n  </div>\n  <div class=\"helper_box\" v-if=\"Page.theme != 'main.tot.css'\">\n    <div id=\"helper\" style=\"height: 80vh\">\n      <div id=\"helperContainer\">\n        <div>\n          <div class=\"helper_name\">{{explanation}}{{colon}}</div>\n          <div class=\"helper_desc\"><li>{{sysInfo}}</li></div>\n        </div>\n        <div v-for=\"help in text\">\n          <div class=\"helper_name\">{{help.title}}</div>\n          <div class=\"helper_desc\" v-html=\"help.item\"></div>\n        </div>\n      </div>\n    </div>\n  </div>\n</div>\n"
          },
