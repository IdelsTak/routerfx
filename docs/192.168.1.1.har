          "content": {
            "size": 20415,
            "mimeType": "text/html",
            "compression": 0,
            "text": "<meta http-equiv=\"Content-Type\" content=\"text/html; charset=UTF-8\" />\n<!-- <link rel=\"stylesheet\" href=\"../font/icon_menu/iconfont.css\"> -->\n<script src=\"../js/home.js\"></script>\n<div id=\"index_template\">\n  <div\n    id=\"header\"\n    :style=\"{height:(isMexicoLogo ||Page.logoPath=='logo_claro.svg'?'110px':'')}\"\n    :class=\"[isMexicoLogo?'header':'',Page.logoPath=='logo_claro.svg'?'claro_header':'']\"\n  >\n    <h2\n      v-if=\"Page.aeraId=='NG0131'\"\n      style=\"position: absolute; left: 90px; font-size: 14px; top: 12px\"\n    >\n      MTN Broadband 5G Router {{Page.titleModel}}\n    </h2>\n    <div\n      style=\"\n        position: absolute;\n        width: 100%;\n        color: red;\n        height: 30px;\n        line-height: 30px;\n        text-align: center;\n        font-size: 16px;\n        font-weight: bold;\n      \"\n      id=\"simRemind\"\n    ></div>\n    <div\n      @click=\"changePage\"\n      style=\"\n        cursor: pointer;\n        position: absolute;\n        right: 200px;\n        top: 0px;\n        color: #0085d0;\n        text-decoration: underline;\n        font-size: 20px;\n        font-weight: bold;\n        display: none;\n      \"\n      id=\"isShowRefresh\"\n    >\n      刷新\n    </div>\n    <div\n      class=\"logo_right claro_right\"\n      v-if=\"Page.logoPath=='logo_claro.svg' && Page.aeraId == 'CO0719'\"\n    >\n      <img src=\"./images/logo_claro_right.svg\" alt=\"\" style=\"height: 76px\" />\n    </div>\n    <div class=\"logo_right\" style=\"display: none\" v-show=\"isMexicoLogo\">\n      <img src=\"./images/logo_right2.png\" alt=\"\" />\n    </div>\n    <div class=\"icon_ais\" v-if=\"Page.aeraId == 'IO24008'\">\n      <a href=\"https://bit.ly/3wgwA9D\" target=\"_blank\">\n        <img src=\"./images/icon_ais_postpaid.png\" alt=\"\" />\n        <span>{{postpaid}}</span>\n      </a>\n      <a href=\"https://bit.ly/3OFDjR2\" target=\"_blank\">\n        <img src=\"./images/icon_ais_prepaid.png\" alt=\"\" />\n        <span>{{prepaid}}</span>\n      </a>\n    </div>\n    <div\n      id=\"userinfo\"\n      :class=\"[isMexicoLogo||Page.logoPath=='logo_claro.svg'?'userinfo':'']\"\n      style=\"\n        z-index: 1000;\n        cursor: pointer;\n        position: absolute;\n        display: flex;\n        align-items: center;\n      \"\n      :style=\"{right:(isMexicoLogo||Page.logoPath=='logo_claro.svg'?'40px':'60px'),top:(isMexicoLogo||Page.logoPath=='logo_claro.svg'?'40px':'25px')}\"\n    >\n      <el-dropdown\n        placement=\"bottom-start\"\n        trigger=\"hover\"\n        :hide-on-click=\"false\"\n      >\n        <div id=\"user-type\">\n          <i class=\"el-icon-user\" style=\"font-size: 22px\"></i>\n        </div>\n        <el-dropdown-menu\n          slot=\"dropdown\"\n          style=\"margin-right: 20px; min-width: 160px\"\n        >\n          <el-dropdown-item>\n            <div style=\"font-size: 12px; padding-right: 20px\">\n              <span>{{username}}</span>\n            </div>\n          </el-dropdown-item>\n          <el-dropdown-item divided></el-dropdown-item>\n          <el-dropdown-item v-if=\"languageSelectShow\" class=\"lang-select-menu\">\n            <div style=\"font-size: 12px\">{{DOC.login.language}}</div>\n            <div class=\"lang-select-box\">\n              <el-dropdown-item\n                @click.native=\"changeLanguageSelect(item.value)\"\n                v-for=\"item in languageSelectList\"\n                :key=\"item.value\"\n                style=\"margin: 5px 0; border-radius: 5px\"\n              >\n                <div\n                  style=\"\n                    display: flex;\n                    align-items: center;\n                    justify-content: space-between;\n                  \"\n                >\n                  <div style=\"font-size: 12px\">{{item.name}}</div>\n                  <i\n                    class=\"el-icon-circle-check\"\n                    v-show=\"languageSelectValue==item.value\"\n                  ></i>\n                </div>\n              </el-dropdown-item>\n            </div>\n          </el-dropdown-item>\n          <el-dropdown-item>\n            <div id=\"logout\" @click=\"clickLogout\" style=\"font-size: 12px\">\n              {{logout}}\n            </div>\n          </el-dropdown-item>\n        </el-dropdown-menu>\n      </el-dropdown>\n    </div>\n    <div id=\"timeinfo\"></div>\n    <div\n      id=\"siginfo\"\n      :style=\"{top:(isMexicoLogo||Page.logoPath=='logo_claro.svg'?'44px':'')}\"\n      :class=\"[isMexicoLogo?'siginfo':'']\"\n    >\n      <table\n        cellpadding=\"0\"\n        cellspacing=\"4\"\n        style=\"margin: 0 auto\"\n        :class=\"[isMexicoLogo?'siginfo_table':'']\"\n      >\n        <tr>\n          <td id=\"networkOperator\" style=\"display: none; padding-right: 10px\">\n            {{network_operator}}\n          </td>\n          <td>\n            <div id=\"voiceInfo\" :title=\"DOC.sip.voipReg3\"></div>\n          </td>\n          <td id=\"flightMode\" style=\"display: none\">\n            <img src=\"../images/flight-mode.png\" alt=\"\" />\n          </td>\n          <td id=\"netInfo\"></td>\n          <td id=\"simInfo\"></td>\n          <td id=\"lteUsbInfo\"></td>\n          <td id=\"wifiInfo\" v-if=\"Page.supportWifi2g\"></td>\n          <td id=\"wifiInfo5g\" v-if=\"Page.supportWifi5g\"></td>\n          <td id=\"lan1\" style=\"display: none\"></td>\n          <td id=\"lan2\" style=\"display: none\"></td>\n          <td id=\"lan3\" style=\"display: none\"></td>\n          <td id=\"lan4\" style=\"display: none\"></td>\n          <td id=\"wan1\" style=\"display: none\"></td>\n          <!-- SMS_INFO -->\n          <td id=\"smsInfo\" style=\"display: none\"></td>\n          <td id=\"dataSwitch\" style=\"display: none\"></td>\n          <td\n            id=\"sms\"\n            v-if=\"Page.pageHideCheck(107) && Page.aeraId!='IN0345'\"\n            @click=\"toSMS\"\n            :title=\"smsTitle\"\n            style=\"cursor: pointer\"\n          >\n            <i\n              class=\"el-icon-chat-dot-round\"\n              style=\"font-size: 18px\"\n              :class=\"smsStatus\"\n            ></i>\n            <i\n              class=\"sms-icon-dot-num\"\n              v-show=\"smsStatus !== 'sms-close' && unreadTotal>0\"\n              >{{unreadTotal}}</i\n            >\n          </td>\n          <td\n            style=\"cursor: pointer\"\n            v-if=\"Page.pageHideCheck(124) && fanStatus!=''\"\n          >\n            <img\n              style=\"height: 24px; width: 24px\"\n              :src=\"fanStatus=='0'?'/images/fan_close.png':fanStatus=='-1'?'/images/fan_fail.png':'/images/fan_open.png'\"\n              alt=\"\"\n              :title=\"fanStatus=='0'?DOC.lbl.fanClose:fanStatus=='1'?DOC.lbl.windSpeed1:fanStatus=='2'?DOC.lbl.windSpeed2:fanStatus=='3'?DOC.lbl.windSpeed3:fanStatus=='4'?DOC.lbl.windSpeed4:DOC.lbl.fanFail\"\n            />\n          </td>\n          <td id=\"batteryExist\" style=\"display: none\"></td>\n          <td id=\"batteryExistTitle\" style=\"display: none\"></td>\n        </tr>\n      </table>\n    </div>\n  </div>\n  <div class=\"statusBarTitle\" v-if=\"!LockBox && Page.aeraId=='MX0268'\">\n    Quamtum Connect 2\n  </div>\n  <div\n    class=\"mexico_footer\"\n    v-if=\"!LockBox && Page.aeraId=='MX0268'\"\n    style=\"border-bottom: 1px solid #0085d0\"\n  >\n    <ul class=\"mexico_url\">\n      <li>\n        <a href=\"https://www.claroideas.com\" target=\"_blank\">\n          <div style=\"background-image: url(/images/mexico/Recurso2.png)\"></div\n        ></a>\n        <p>Portal Claro ideas</p>\n      </li>\n      <li>\n        <a href=\"https://www.clarodrive.com\" target=\"_blank\"\n          ><div\n            style=\"background-image: url(/images/mexico/claro_drive.png)\"\n          ></div\n        ></a>\n        <p>Claro drive</p>\n      </li>\n      <li>\n        <a href=\"https://www.claroshop.com\" target=\"_blank\"\n          ><div\n            style=\"background-image: url(/images/mexico/claro_shop.png)\"\n          ></div\n        ></a>\n        <p>Claro shop</p>\n      </li>\n      <li>\n        <a href=\"https://www.clarovideo.com\" target=\"_blank\"\n          ><div style=\"background-image: url(/images/mexico/video.png)\"></div\n        ></a>\n        <p>Claro video</p>\n      </li>\n      <li>\n        <a href=\"https://www.claromusica.com\" target=\"_blank\"\n          ><div\n            style=\"background-image: url(/images/mexico/claro_music.png)\"\n          ></div\n        ></a>\n        <p>Claro música</p>\n      </li>\n      <li>\n        <a href=\"https://www.mitelcel.com\" target=\"_blank\"\n          ><div style=\"background-image: url(/images/mexico/miTelcel.png)\"></div\n        ></a>\n        <p>Mi Telcel</p>\n      </li>\n    </ul>\n  </div>\n  <!-- claro定制区域码控制链接 -->\n  <div\n    class=\"mexico_footer\"\n    v-if=\"!LockBox && Page.aeraId=='MX0268-DOM_CL'\"\n    style=\"border-bottom: 1px solid #0085d0\"\n  >\n    <ul class=\"mexico_url\">\n      <li>\n        <a href=\"https://do.claroideas.com\" target=\"_blank\"\n          ><div\n            style=\"background-image: url(/images/mexico/claro_ideas.png)\"\n          ></div\n        ></a>\n        <p>Portal Claro ideas</p>\n      </li>\n      <li>\n        <a href=\"https://www.clarodrive.com/?country=dominicana\" target=\"_blank\"\n          ><div\n            style=\"background-image: url(/images/mexico/claro_drive.png)\"\n          ></div\n        ></a>\n        <p>Claro drive</p>\n      </li>\n      <li>\n        <a href=\"https://tienda.claro.com.do\" target=\"_blank\"\n          ><div\n            style=\"background-image: url(/images/mexico/claro_shop.png)\"\n          ></div\n        ></a>\n        <p>Claro shop</p>\n      </li>\n      <li>\n        <a\n          href=\"https://www.claro.com.do/personas/servicios/entretenimiento/claro-video/\"\n          target=\"_blank\"\n          ><div style=\"background-image: url(/images/mexico/video.png)\"></div\n        ></a>\n        <p>Claro video</p>\n      </li>\n      <li>\n        <a href=\"https://www.claromusica.com/landing/DO\" target=\"_blank\"\n          ><div\n            style=\"background-image: url(/images/mexico/claro_music.png)\"\n          ></div\n        ></a>\n        <p>Claro música</p>\n      </li>\n      <li>\n        <a href=\"https://miclaro.claro.com.do/#/login\" target=\"_blank\"\n          ><div style=\"background-image: url(/images/mi_claro.png)\"></div\n        ></a>\n        <p>Mi Claro</p>\n      </li>\n    </ul>\n  </div>\n  <div\n    id=\"main\"\n    style=\"overflow: hidden\"\n    :style=\"{'border-bottom':(isMexicoLogo?'1px solid #0085D0':''),'max-height':(isMexicoLogo?'590PX':''),}\"\n  >\n    <div\n      id=\"left\"\n      :class=\"[Page.language == 'el'?'el_left':'']\"\n      :style=\"{'max-height':(isMexicoLogo?'590PX':'')}\"\n    >\n      <div id=\"left_t\"></div>\n      <div id=\"left_m\">\n        <!-- <div id=\"menu\"></div> -->\n        <div>\n          <el-row class=\"tac\">\n            <el-col>\n              <el-menu\n                ref=\"menu\"\n                :unique-opened=\"true\"\n                :default-active=\"defaultIndex\"\n                class=\"el-menu-vertical-demo\"\n                @open=\"handleOpen\"\n                @close=\"handleClose\"\n              >\n                <el-submenu\n                  :index=\"index+1\"\n                  v-for=\"(item,index) in menu\"\n                  :id=\"item.css\"\n                  :class=\"[item.isSelect?'menu-active':'menu-noActive',index == '3'?'special_menu':'',languageSelectValue=='por'?'isPor':'',languageSelectValue=='it'?'isIt':''  ]\"\n                >\n                  <template slot=\"title\">\n                    <span\n                      :id=\"'child-'+item.bodys[0].id\"\n                      :class=\"[item.isSelect?'menu1-active':false,(index=='2')?'needJumpFirst':'']\"\n                      class=\"menu_span\"\n                      >{{item.text}}</span\n                    >\n                  </template>\n                  <el-menu-item-group v-for=\"(option,index1) in item.bodys\">\n                    <el-menu-item\n                      @click=\"clickMenu(option.id,index,index1)\"\n                      :id=\"option.id\"\n                      :index=\"index+'-'+index1\"\n                      :class=\"[(index=='2'&&index1=='0')?'needJump':'']\"\n                      >{{option.text}}</el-menu-item\n                    >\n                  </el-menu-item-group>\n                </el-submenu>\n              </el-menu>\n            </el-col>\n          </el-row>\n        </div>\n      </div>\n      <div id=\"left_b\"></div>\n    </div>\n\n    <div\n      id=\"right\"\n      :class=\"[Page.language == 'el'?'el_right':'']\"\n      :style=\"{'max-height':(isMexicoLogo?'590PX':'')}\"\n    ></div>\n  </div>\n\n  <div\n    id=\"footer\"\n    :style=\"{height:(isMexicoLogo||Page.logoPath=='logo_claro.svg'?'0px':'')}\"\n  >\n    <span v-if=\"Page.aeraId=='NG0131'\"\n      >Contact Customer Care via e-mail on mtnbroadband.ng@mtn.com; or Dial 217\n      (toll-free) or 08031021700 (other network) or MTN website\n      <a target=\"_blank\" href=\"http://www.mtn.ng/broadband\"\n        >www.mtn.ng/broadband</a\n      ></span\n    >\n    <span v-else-if=\"Page.aeraId=='IN0345'\" style=\"text-align: center\"\n      >Customer Support 1800 103 0405</span\n    >\n    <span\n      v-else-if=\"Page.logoPath=='logo_langchao.png'\"\n      style=\"text-align: center\"\n      >浪潮通信技术有限公司</span\n    >\n    <span\n      v-else\n      id=\"spanFooter\"\n      v-if=\"!isMexicoLogo && Page.logoPath!='logo_claro.svg'\"\n      >{{copyright}}</span\n    >\n  </div>\n  <div class=\"claro_food\" v-if=\"Page.logoPath=='logo_claro.svg'\">\n    <div style=\"height: 43px; width: 43px\">\n      <img src=\"./images/claro_logo_quamtum_grey.svg\" alt=\"\" />\n    </div>\n    <div style=\"line-height: 43px; display: inline-block\">\n      <div style=\"margin-bottom: 0; margin-top: auto\">\n        Quamtum Connectivity de México S.A. of C.V. © 2023. All rights reserved\n        <a target=\"_blank\" href=\"https://www.quamtumconnectivity.com\"\n          >www.quamtumconnectivity.com</a\n        >\n      </div>\n    </div>\n  </div>\n  <div class=\"mexico_login\" v-if=\"!LockBox && isMexicoLogo\">\n    <a href=\"https://www.quamtumconnectivity.com\" target=\"_blank\">\n      <img src=\"/images/mexico/home_footer.png\" alt=\"\" />\n    </a>\n  </div>\n  <div id=\"mask\" :class=\"[isMexicoLogo?'mask_mexico':'']\"></div>\n\n  <div id=\"info_box\">\n    <div id=\"info_head\"></div>\n    <div id=\"info_close\">\n      <input id=\"btnClose\" type=\"button\" :value=\"close\" @click=\"btnClose\" />\n    </div>\n    <div id=\"info_tab_head\"></div>\n    <div id=\"info_body\">\n      <div id=\"info_main\"></div>\n    </div>\n  </div>\n\n  <div id=\"progress_box\">\n    <div id=\"progress_info\"></div>\n    <div id=\"progress_bar\">\n      <div id=\"progress_status\"></div>\n    </div>\n  </div>\n  <!-- pinpuk锁屏 -->\n  <div id=\"pingFormId1\">\n    <div class=\"edit_boxhome\" v-if=\"LockBox\">\n      <!-- 顶部 -->\n      <div class=\"detail\">\n        <div id=\"edit_title\" v-if=\"isShowPin\">\n          {{pinVerification}}\n          <i\n            class=\"el-icon-circle-close\"\n            @click=\"lockBoxbtnClose\"\n            id=\"pinBoxClose\"\n          ></i>\n        </div>\n        <div id=\"edit_title\" v-if=\"isShowPuk\">\n          {{puk}}\n          <i\n            class=\"el-icon-circle-close\"\n            @click=\"lockBoxbtnClose\"\n            id=\"pinBoxClose\"\n          ></i>\n        </div>\n      </div>\n      <!-- 顶部结束 -->\n\n      <table class=\"detail\" cellspacing=\"0\" style=\"width: 80%\">\n        <!-- 输入PIN码 -->\n        <tr v-if=\"isShowPin\">\n          <th><span>{{pinCode}}{{colon}}</span></th>\n          <td>\n            <!-- 使用element输入框会有重绘问题，导致输入框焦点丢失 -->\n            <input\n              type=\"text\"\n              maxlength=\"8\"\n              style=\"width: 220px\"\n              v-model=\"pinPassword\"\n              name=\"pin\"\n              class=\"homeinput\"\n            />\n          </td>\n        </tr>\n        <tr v-if=\"isShowPin\">\n          <th></th>\n          <td class=\"redTip\">\n            <div>{{leftPin}}</div>\n          </td>\n        </tr>\n        <!-- 输入提示 -->\n        <tr v-if=\"isShowPin\">\n          <th></th>\n          <td>\n            <div class=\"cmt\">{{pinSetRemind}}</div>\n          </td>\n        </tr>\n        <!-- 输入PIN码结束-->\n\n        <!-- 三次PIN码错误的PUK码验证 -->\n        <tr v-if=\"isShowPuk\">\n          <th><span>{{puk}}{{colon}}</span></th>\n          <td>\n            <input\n              type=\"text\"\n              maxlength=\"8\"\n              style=\"width: 220px\"\n              v-model=\"pukPassword\"\n              name=\"pukPassword1\"\n              class=\"homeinput\"\n            />\n          </td>\n        </tr>\n        <tr v-if=\"isShowPuk\">\n          <th><span>{{newPin}}{{colon}}</span></th>\n          <td>\n            <input\n              type=\"text\"\n              maxlength=\"8\"\n              style=\"width: 220px\"\n              v-model=\"pukPinPassword\"\n              name=\"pukPinPassword1\"\n              class=\"homeinput\"\n            />\n          </td>\n        </tr>\n        <tr v-if=\"isShowPuk\">\n          <th><span>{{newPinConfirm}}{{colon}}</span></th>\n          <td>\n            <input\n              type=\"text\"\n              maxlength=\"8\"\n              style=\"width: 220px\"\n              v-model=\"pukPinPasswordConfirm\"\n              name=\"pukPinPasswordConfirm1\"\n              class=\"homeinput\"\n            />\n          </td>\n        </tr>\n        <tr v-if=\"isShowPuk\">\n          <th></th>\n          <td class=\"redTip\">\n            <div>{{leftPuk}}</div>\n          </td>\n        </tr>\n        <!-- puk码验证结束 -->\n        <!-- 保存按钮 -->\n        <tr>\n          <th>&nbsp;</th>\n          <td>\n            <el-button type=\"primary\" @click=\"btnSave\" data-id=\"home-btn-save\"\n              >{{save}}</el-button\n            >\n          </td>\n        </tr>\n        <!-- 保存按钮结束 -->\n      </table>\n    </div>\n  </div>\n  <!-- 锁屏结束 -->\n</div>\n<style>\n  .el-menu-item {\n    white-space: normal !important;\n    display: flex;\n    align-items: center;\n    line-height: 25px !important;\n  }\n  li.isIt > ul > li > ul > li {\n    line-height: 15px !important;\n  }\n  .isIt.el-submenu.is-active .el-submenu__title * {\n    font-size: 15px !important;\n  }\n  .isIt > div.el-submenu__title:hover * {\n    font-size: 15px;\n  }\n  li.isIt.special_menu > div > span.menu_span {\n    white-space: break-spaces;\n    line-height: 25px;\n    display: inline-block;\n  }\n  li.isPor > ul > li > ul > li {\n    line-height: 15px !important;\n  }\n  .isPor.el-submenu.is-active .el-submenu__title * {\n    font-size: 13px !important;\n  }\n  .isPor > div.el-submenu__title:hover * {\n    color: white !important;\n    font-size: 13px;\n  }\n  .isPor.special_menu > div.el-submenu__title:hover * {\n    color: white !important;\n    font-size: 13px;\n    white-space: break-spaces;\n    line-height: 25px;\n  }\n  li.special_menu.isPor .el-submenu__title:hover {\n    background-color: #0099cc;\n    font-size: 19px !important;\n    font-weight: bold !important;\n    color: #ffffff;\n  }\n  .el-submenu.is-active.special_menu.isPor .el-submenu__title {\n    background: #0099cc;\n    color: #fff;\n    border-bottom-color: #409eff;\n    white-space: break-spaces;\n    line-height: 25px;\n  }\n  .menu-noActive.special_menu.isPor > div {\n    font-size: 14px;\n    white-space: break-spaces;\n    line-height: 25px;\n    padding-left: 15px !important;\n  }\n  li.special_menu.isPor > div > span.menu_span {\n    display: inline-block;\n    width: 145px;\n  }\n  #header .isPor .el-input {\n    width: 110px;\n  }\n  .claro_food {\n    /* height:46px; */\n    width: 100%;\n    text-align: center;\n    display: flex;\n    justify-content: center;\n    align-items: center;\n  }\n  .sms-icon-dot-num {\n    width: 14px;\n    height: 14px;\n    border-radius: 50%;\n    background-color: #f56c6c;\n    display: block;\n    position: relative;\n    bottom: 5px;\n    right: 10px;\n    float: right;\n    line-height: 14px;\n    font-size: 10px;\n    font-family: Consolas, Verdana;\n    text-align: center;\n    color: #fff;\n  }\n  @keyframes blink {\n    0% {\n      opacity: 1;\n    }\n    50% {\n      opacity: 0;\n    }\n    100% {\n      opacity: 1;\n    }\n  }\n\n  .blink {\n    animation: blink 3s infinite;\n  }\n  #user-type {\n    padding: 5px;\n    border-radius: 50%;\n    background-color: #b3e5fc;\n  }\n  .lang-select-menu {\n    position: relative;\n  }\n  .lang-select-box {\n    display: none;\n    float: left;\n    right: 100%;\n    top: 0px;\n    position: absolute;\n    width: 150px;\n    background-color: #fff;\n    padding: 5px;\n    border-radius: 5px;\n    border: solid 1px #eee;\n  }\n  .lang-select-menu:hover .lang-select-box {\n    display: block;\n  }\n  .claro_header {\n    background-size: 230px;\n  }\n  @media screen and (max-width: 1500px) {\n    .claro_right {\n      right: 15% !important;\n    }\n    .claro_header {\n      background-size: 200px;\n      background-position: 20px !important;\n    }\n  }\n</style>\n"
          },
