<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import org.kordamp.ikonli.javafx.*?>

<VBox id="networkPathCard" styleClass="card-surface" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1">
  <children>
    <Label styleClass="card-title" text="NETWORK" />
    <HBox styleClass="path-row">
      <children>
        <Label id="routerPathNode" fx:id="routerPathNode" text="ROUTER">
          <styleClass>
            <String fx:value="path-node" />
            <String fx:value="path-node-active" />
          </styleClass>
          <graphic>
            <FontIcon iconLiteral="fas-network-wired">
                     <styleClass>
                        <String fx:value="dashboard-icon-glyph" />
                        <String fx:value="path-node-icon" />
                     </styleClass></FontIcon>
          </graphic>
        </Label>
        <Label id="primaryDnsLink" fx:id="primaryDnsLink" text="------">
          <styleClass>
            <String fx:value="path-link" />
            <String fx:value="path-link-active" />
          </styleClass>
        </Label>
        <Label id="internetPathNode" fx:id="internetPathNode" text="INTERNET">
          <styleClass>
            <String fx:value="path-node" />
            <String fx:value="path-node-active" />
          </styleClass>
          <graphic>
            <FontIcon iconLiteral="fas-globe">
                     <styleClass>
                        <String fx:value="dashboard-icon-glyph" />
                        <String fx:value="path-node-icon" />
                     </styleClass></FontIcon>
          </graphic>
        </Label>
        <Label id="secondaryDnsLink" fx:id="secondaryDnsLink" text="- - - -">
          <styleClass>
            <String fx:value="path-link" />
            <String fx:value="path-link-fallback" />
          </styleClass>
        </Label>
        <Label id="primaryDnsPathNode" fx:id="primaryDnsPathNode" text="DNS1">
          <styleClass>
            <String fx:value="path-node" />
            <String fx:value="path-node-active" />
          </styleClass>
          <graphic>
            <FontIcon iconLiteral="fas-server">
                     <styleClass>
                        <String fx:value="dashboard-icon-glyph" />
                        <String fx:value="path-node-icon" />
                     </styleClass></FontIcon>
          </graphic>
        </Label>
        <Label text="- - -">
          <styleClass>
            <String fx:value="path-link" />
            <String fx:value="path-link-inactive" />
          </styleClass>
        </Label>
        <Label id="secondaryDnsPathNode" fx:id="secondaryDnsPathNode" text="DNS2">
          <styleClass>
            <String fx:value="path-node" />
            <String fx:value="path-node-fallback" />
          </styleClass>
          <graphic>
            <FontIcon iconLiteral="fas-server">
                     <styleClass>
                        <String fx:value="dashboard-icon-glyph" />
                        <String fx:value="path-node-icon" />
                     </styleClass></FontIcon>
          </graphic>
        </Label>
      </children>
    </HBox>
    <GridPane styleClass="metrics-grid">
      <children>
        <Label styleClass="metric-label" text="IP" GridPane.columnIndex="0" GridPane.rowIndex="0" />
        <Label id="ipValue" fx:id="ipValue" styleClass="metric-value" text="-" GridPane.columnIndex="1" GridPane.rowIndex="0" />

        <Label styleClass="metric-label" text="WAN MAC" GridPane.columnIndex="0" GridPane.rowIndex="1" />
        <Label id="wanMacValue" fx:id="wanMacValue" styleClass="metric-value" text="-" GridPane.columnIndex="1" GridPane.rowIndex="1" />

        <Label styleClass="metric-label" text="PRIMARY DNS" GridPane.columnIndex="0" GridPane.rowIndex="2" />
        <Label id="primaryDnsValue" fx:id="primaryDnsValue" styleClass="metric-value" text="-" GridPane.columnIndex="1" GridPane.rowIndex="2" />

        <Label styleClass="metric-label" text="SECONDARY DNS" GridPane.columnIndex="0" GridPane.rowIndex="3" />
        <Label id="secondaryDnsValue" fx:id="secondaryDnsValue" styleClass="metric-value" text="-" GridPane.columnIndex="1" GridPane.rowIndex="3" />

        <Label styleClass="metric-label" text="IPV6" GridPane.columnIndex="0" GridPane.rowIndex="4" />
        <Label id="ipv6Value" fx:id="ipv6Value" styleClass="metric-value" text="-" GridPane.columnIndex="1" GridPane.rowIndex="4" />

        <Label styleClass="metric-label" text="PRIMARY IPV6 DNS" GridPane.columnIndex="0" GridPane.rowIndex="5" />
        <Label id="primaryIpv6DnsValue" fx:id="primaryIpv6DnsValue" styleClass="metric-value" text="-" GridPane.columnIndex="1" GridPane.rowIndex="5" />

        <Label styleClass="metric-label" text="SECONDARY IPV6 DNS" GridPane.columnIndex="0" GridPane.rowIndex="6" />
        <Label id="secondaryIpv6DnsValue" fx:id="secondaryIpv6DnsValue" styleClass="metric-value" text="-" GridPane.columnIndex="1" GridPane.rowIndex="6" />
      </children>
         <columnConstraints>
            <ColumnConstraints />
            <ColumnConstraints />
         </columnConstraints>
         <rowConstraints>
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
            <RowConstraints />
         </rowConstraints>
    </GridPane>
    <HBox styleClass="network-summary">
      <children>
        <Label styleClass="network-summary-text" text="Carrier aggregation active" />
        <Pane HBox.hgrow="ALWAYS" />
        <Label styleClass="network-summary-meta" text="PCI" />
        <Label id="pciMirrorValue" fx:id="pciMirrorValue" styleClass="network-summary-meta" text="-" />
        <Label styleClass="network-summary-meta" text="EARFCN" />
        <Label id="earfcnMirrorValue" fx:id="earfcnMirrorValue" styleClass="network-summary-meta" text="-" />
      </children>
    </HBox>
  </children>
</VBox>
